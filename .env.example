# ---- TukiVet env template ----
# Copia este archivo a .env y completa los valores.
# El .env real NUNCA se commitea (ya está en .gitignore).

# Entorno
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Base de datos
DATABASE_URL=postgresql+asyncpg://tukivet:tukivet_dev@localhost:5432/tukivet

# Redis (cache, rate limit, cola ARQ)
REDIS_URL=redis://localhost:6379/0

# Seguridad
SECRET_KEY=change-me-in-production-please-its-just-development-32chars
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# CORS (lista separada por coma)
CORS_ORIGINS=http://localhost:3000

# Object storage (MinIO local / S3-compatible en prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tukivet-dev
S3_REGION=us-east-1

# TukiFact (facturación electrónica SUNAT)
TUKIFACT_API_KEY=TF_test_replace_me
TUKIFACT_ENVIRONMENT=sandbox
TUKIFACT_WEBHOOK_SECRET=

# Twilio WhatsApp Business (recordatorios y notificaciones)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Modo seguro de comunicaciones (en dev solo envía a la lista)
SAFE_RECIPIENTS_ONLY=true
SAFE_RECIPIENTS=+51999999999

# Sentry (opcional)
SENTRY_DSN=

# Feature flags
ENABLE_ONLINE_PAYMENTS=false
ENABLE_AI_SOAP=false
