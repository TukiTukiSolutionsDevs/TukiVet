# ---- Razas / TukiVet env template (PRODUCCIÓN) ----
# Copia este archivo a .env.prod en el servidor y completa los valores reales.
# El archivo .env.prod NUNCA se commitea.

# Entorno
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Base de datos (Docker network: postgres)
POSTGRES_DB=tukivet
POSTGRES_USER=tukivet
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_FUERTE_AQUI
DATABASE_URL=postgresql+asyncpg://tukivet:CAMBIAR_PASSWORD_FUERTE_AQUI@postgres:5432/tukivet

# Redis
REDIS_URL=redis://redis:6379/0

# Seguridad (genera con: openssl rand -hex 32)
SECRET_KEY=GENERAR_CON_openssl_rand_hex_32
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# CORS (dominios públicos)
CORS_ORIGINS=https://razas.com.pe,https://www.razas.com.pe,https://app.razas.com.pe

# Object storage (MinIO interno)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_MINIO_PASSWORD_FUERTE
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CAMBIAR_MINIO_PASSWORD_FUERTE
S3_BUCKET=razas-prod
S3_REGION=us-east-1

# TukiFact (facturación SUNAT — producción)
TUKIFACT_API_KEY=TF_live_replace_me
TUKIFACT_ENVIRONMENT=production
TUKIFACT_WEBHOOK_SECRET=

# Twilio WhatsApp Business
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Modo seguro (poner false en producción real)
SAFE_RECIPIENTS_ONLY=false
SAFE_RECIPIENTS=

# Sentry
SENTRY_DSN=

# Feature flags
ENABLE_ONLINE_PAYMENTS=false
ENABLE_AI_SOAP=false

# Caddy (Let's Encrypt)
ACME_EMAIL=admin@razas.com.pe
